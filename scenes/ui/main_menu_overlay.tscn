[sub_resource type="Shader" id="ShaderSunGlow"]
code = "shader_type canvas_item;\nrender_mode unshaded, blend_add;\nuniform float strength : hint_range(0.0, 1.0) = 0.18;\nvoid fragment() {\n\tvec2 sun_point = (UV - vec2(0.735, 0.425)) * vec2(1.0, 1.78);\n\tfloat sun_distance = length(sun_point);\n\tfloat sun_halo = smoothstep(0.30, 0.045, sun_distance) * 0.72;\n\tfloat left_line = smoothstep(0.018, 0.0, abs(UV.y - (0.865 - UV.x * 0.22))) * (1.0 - smoothstep(0.62, 0.73, UV.x));\n\tfloat right_line = smoothstep(0.022, 0.0, abs(UV.y - (UV.x - 0.075))) * smoothstep(0.70, 0.80, UV.x);\n\tfloat road_glow = max(left_line, right_line);\n\tvec3 glow_color = vec3(1.0, 0.18, 0.50) * sun_halo + vec3(0.95, 0.08, 0.72) * road_glow;\n\tfloat alpha = max(sun_halo * 0.72, road_glow) * strength;\n\tCOLOR = vec4(glow_color, alpha);\n}\n"

[sub_resource type="ShaderMaterial" id="MaterialSunGlow"]
shader = SubResource("ShaderSunGlow")
shader_parameter/strength = 0.22

